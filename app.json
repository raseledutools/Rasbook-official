{
  "expo": {
    "name": "RasBook",
    "slug": "rasbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1877F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rasbook.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#1877F2"
      },
      "package": "com.rasbook.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./src/assets/favicon.png",
      "bundler": "webpack"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "RasBook needs access to your photos.",
          "cameraPermission": "RasBook needs access to your camera."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/icon.png",
          "color": "#1877F2"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "rasbook-5159d"
      }
    }
  }
}
