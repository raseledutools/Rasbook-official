{
  "expo": {
    "name": "RasBook",
    "slug": "rasbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rasbook.app",
      "infoPlist": {
        "NSCameraUsageDescription": "RasBook needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "RasBook needs microphone access for voice and video calls.",
        "UIBackgroundModes": [
          "voip",
          "audio",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.rasbook.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "FOREGROUND_SERVICE_CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "READ_PHONE_STATE",
        "MANAGE_OWN_CALLS",
        "CALL_PHONE",
        "VIBRATE",
        "WAKE_LOCK",
        "USE_FULL_SCREEN_INTENT",
        "SYSTEM_ALERT_WINDOW"
      ],
      "intentFilters": []
    },
    "web": {
      "favicon": "./src/assets/favicon.png",
      "bundler": "metro",
      "publicPath": "/Rasbook-official/"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "kotlinVersion": "1.9.10"
          },
          "ios": {
            "deploymentTarget": "13.4"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6fc3963c-2dd9-44b0-b1ae-c50e86d00fdf"
      }
    }
  }
}